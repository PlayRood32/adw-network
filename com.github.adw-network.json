{
  "app-id": "com.github.adw-network",
  "x-version": "1.0.0",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "command": "adwaita-network",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--talk-name=org.freedesktop.NetworkManager",
    "--talk-name=org.freedesktop.ModemManager1",
    "--talk-name=org.freedesktop.secrets",
    "--filesystem=xdg-config/adw-network:create",
    "--filesystem=xdg-data/adw-network:create",
    "--filesystem=/var/lib/NetworkManager:ro",
    "--filesystem=/run/NetworkManager:ro",
    "--filesystem=/sys/class/net:ro",
    "--filesystem=/var/lib/dnsmasq:ro",
    "--filesystem=/var/lib/misc:ro",
    "--filesystem=/var/db:ro",
    "--filesystem=/usr/share/hwdata:ro",
    "--filesystem=/usr/share/misc:ro",
    "--filesystem=/usr/share/ieee-data:ro",
    "--filesystem=/var/lib/ieee-data:ro"
  ],
  "modules": [
    {
      "name": "adw-network",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --release --locked",
        "install -Dm755 target/release/adwaita-network /app/bin/adwaita-network",
        "install -Dm644 data/com.github.adw-network.desktop /app/share/applications/com.github.adw-network.desktop",
        "install -Dm644 data/icons/hicolor/scalable/apps/icon.png /app/share/icons/hicolor/scalable/apps/com.github.adw-network.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
